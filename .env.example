# Extension build configuration
PLASMO_PUBLIC_PHOTOSWEEP_LICENSE_API_BASE_URL=https://license.photosweep.app
PLASMO_PUBLIC_PHOTOSWEEP_ENTITLEMENT_PUBLIC_KEY=BASE64URL_SPKI_PUBLIC_KEY
# Dev/test only. Never set this in production extension builds.
PLASMO_PUBLIC_PHOTOSWEEP_ALLOW_DEV_ENTITLEMENT=0

# License API configuration
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
PHOTOSWEEP_ALLOWED_ORIGINS=chrome-extension://YOUR_EXTENSION_ID
PHOTOSWEEP_ENTITLEMENT_PRIVATE_KEY=BASE64URL_PKCS8_PRIVATE_KEY
PHOTOSWEEP_STRIPE_PRICE_MINI_CLEANUP=price_...
PHOTOSWEEP_STRIPE_PRICE_CLEANUP_PASS_7D=price_...
PHOTOSWEEP_STRIPE_PRICE_LIFETIME_EARLY_ACCESS=price_...
PHOTOSWEEP_CHECKOUT_SUCCESS_URL=https://photosweep.example/checkout/success
PHOTOSWEEP_CHECKOUT_CANCEL_URL=https://photosweep.example/checkout/cancel
PHOTOSWEEP_RECOVERY_BASE_URL=https://license.photosweep.app
PHOTOSWEEP_RECOVERY_REDIRECT_URL=https://photosweep.example/license/recovered
PHOTOSWEEP_RECOVERY_EMAIL_WEBHOOK_URL=https://mail-automation.example/photosweep/recovery
PHOTOSWEEP_RECOVERY_EMAIL_WEBHOOK_SECRET=replace-with-random-shared-secret
PHOTOSWEEP_COOKIE_SECURE=1
PHOTOSWEEP_LICENSE_STORE_PATH=.photosweep/license-store.json
