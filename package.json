{
  "name": "google-photos-deduper",
  "displayName": "PhotoSweep",
  "version": "2.2.2",
  "description": "Find and review duplicate photos in supported cloud photo libraries",
  "author": "Mack Talcott",
  "scripts": {
    "build:gptk": "git submodule update --init && (test -d Google-Photos-Toolkit/node_modules || npm --prefix Google-Photos-Toolkit install --no-fund --no-audit) && cd Google-Photos-Toolkit && npm run build && cp google_photos_toolkit.user.js ../scripts/google-photos-toolkit.user.js",
    "copy:wasm": "cp node_modules/@mediapipe/tasks-vision/wasm/vision_wasm_internal.js scripts/ && cp node_modules/@mediapipe/tasks-vision/wasm/vision_wasm_internal.wasm scripts/",
    "build:worker": "node_modules/.bin/esbuild workers/embedder.worker.ts --bundle --platform=browser --format=iife --target=es2020 --outfile=scripts/embedder-worker.js",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "test": "vitest run",
    "test:bench": "vitest bench --run",
    "test:watch": "vitest",
    "test:integration": "playwright test --config playwright.config.ts",
    "test:e2e": "playwright test --config playwright.e2e.config.ts",
    "license:serve": "node server/node-server.mjs",
    "stripe:setup-products": "node tools/setup-stripe-products.mjs",
    "sync:scripts": "cp scripts/google-photos-commands.js build/chrome-mv3-dev/scripts/ 2>/dev/null || true",
    "predev": "npm run build:gptk && npm run copy:wasm && npm run build:worker && npm run sync:scripts",
    "dev": "plasmo dev",
    "prebuild": "npm run build:gptk && npm run copy:wasm && npm run build:worker",
    "build": "plasmo build && cp -r build/chrome-mv3-prod/. build/chrome-mv3-dev/",
    "package": "npm run build && plasmo package",
    "release": "bash tools/release.sh",
    "framer:probe": "node tools/framer-probe.mjs"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource/dm-sans": "^5.2.8",
    "@mediapipe/tasks-vision": "^0.10.18",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@plasmohq/messaging": "^0.6.2",
    "@types/canvas-confetti": "^1.9.0",
    "canvas-confetti": "^1.9.4",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-window": "^1.8.10"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/chrome": "0.0.258",
    "@types/node": "^24",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "@types/react-window": "^1.8.8",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.2",
    "fake-indexeddb": "^6.2.5",
    "framer-api": "^0.1.17",
    "happy-dom": "^20.8.9",
    "jsdom": "^29.0.1",
    "plasmo": "^0.90.5",
    "prettier": "3.2.4",
    "typescript": "5.3.3",
    "vite": "^8.0.7",
    "vitest": "^4.1.2"
  },
  "manifest": {
    "side_panel": {
      "default_path": "tabs/scanner-panel.html"
    },
    "permissions": [
      "activeTab",
      "sidePanel",
      "tabs",
      "scripting",
      "webNavigation",
      "storage",
      "unlimitedStorage"
    ],
    "host_permissions": [
      "https://photos.google.com/*",
      "https://photos.googleusercontent.com/*",
      "https://photos.fife.usercontent.google.com/*",
      "https://www.icloud.com/*",
      "https://*.icloud.com/*",
      "https://www.icloud.com.cn/*",
      "https://*.icloud.com.cn/*",
      "https://*.icloud-content.com/*",
      "https://*.icloud-content.com.cn/*",
      "https://www.amazon.com/*",
      "https://www.amazon.ca/*",
      "https://www.amazon.co.uk/*",
      "https://www.amazon.de/*",
      "https://www.amazon.fr/*",
      "https://www.amazon.it/*",
      "https://www.amazon.es/*",
      "https://www.amazon.co.jp/*",
      "https://www.amazon.com.au/*",
      "https://www.amazon.in/*",
      "https://www.amazon.com.br/*",
      "https://www.amazon.com.mx/*",
      "https://www.amazon.nl/*",
      "https://www.amazon.sg/*",
      "https://www.amazon.ae/*",
      "https://www.amazon.sa/*",
      "https://www.amazon.se/*",
      "https://www.amazon.pl/*",
      "https://www.amazon.com.tr/*",
      "https://www.amazon.be/*",
      "https://www.amazon.eg/*",
      "https://thumbnails-photos.amazon.com/*",
      "https://thumbnails-photos.amazon.ca/*",
      "https://thumbnails-photos.amazon.co.uk/*",
      "https://thumbnails-photos.amazon.de/*",
      "https://thumbnails-photos.amazon.fr/*",
      "https://thumbnails-photos.amazon.it/*",
      "https://thumbnails-photos.amazon.es/*",
      "https://thumbnails-photos.amazon.co.jp/*",
      "https://thumbnails-photos.amazon.com.au/*",
      "https://thumbnails-photos.amazon.in/*",
      "https://thumbnails-photos.amazon.com.br/*",
      "https://thumbnails-photos.amazon.com.mx/*",
      "https://thumbnails-photos.amazon.nl/*",
      "https://thumbnails-photos.amazon.sg/*",
      "https://thumbnails-photos.amazon.ae/*",
      "https://thumbnails-photos.amazon.sa/*",
      "https://thumbnails-photos.amazon.se/*",
      "https://thumbnails-photos.amazon.pl/*",
      "https://thumbnails-photos.amazon.com.tr/*",
      "https://thumbnails-photos.amazon.be/*",
      "https://thumbnails-photos.amazon.eg/*",
      "https://*.media-amazon.com/*",
      "https://*.ssl-images-amazon.com/*",
      "https://*.googleusercontent.com/*",
      "https://*.usercontent.google.com/*",
      "https://*.googleapis.com/*",
      "https://license.photosweep.app/*",
      "http://127.0.0.1:8787/*",
      "http://localhost:8787/*",
      "http://127.0.0.1:8788/*",
      "http://localhost:8788/*"
    ],
    "content_security_policy": {
      "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
    },
    "web_accessible_resources": [
      {
        "resources": [
          "scripts/unsafewindow-shim.js",
          "scripts/google-photos-toolkit.user.js",
          "scripts/google-photos-commands.js",
          "scripts/icloud-photos-commands.js",
          "scripts/amazon-photos-commands.js",
          "scripts/vision_wasm_internal.js",
          "scripts/vision_wasm_internal.wasm",
          "scripts/embedder-worker.js",
          "scripts/mobilenet_v3_large.tflite"
        ],
        "matches": [
          "https://photos.google.com/*",
          "https://www.icloud.com/*",
          "https://www.icloud.com.cn/*",
          "https://www.amazon.com/*",
          "https://www.amazon.ca/*",
          "https://www.amazon.co.uk/*",
          "https://www.amazon.de/*",
          "https://www.amazon.fr/*",
          "https://www.amazon.it/*",
          "https://www.amazon.es/*",
          "https://www.amazon.co.jp/*",
          "https://www.amazon.com.au/*",
          "https://www.amazon.in/*",
          "https://www.amazon.com.br/*",
          "https://www.amazon.com.mx/*",
          "https://www.amazon.nl/*",
          "https://www.amazon.sg/*",
          "https://www.amazon.ae/*",
          "https://www.amazon.sa/*",
          "https://www.amazon.se/*",
          "https://www.amazon.pl/*",
          "https://www.amazon.com.tr/*",
          "https://www.amazon.be/*",
          "https://www.amazon.eg/*"
        ]
      }
    ]
  }
}
